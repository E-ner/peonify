# Copy this file to .env and adjust for your machine.

# PostgreSQL connection (install PostgreSQL on Windows, create a "peonify" database)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/peonify

# API port
PORT=5000

# Admin dashboard login (seeded on first boot; change these!)
ADMIN_EMAIL=admin@peonify.com
ADMIN_PASSWORD=peonify-admin

# Secret used to sign admin JWTs — set a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# Paystack (leave empty to run with mock payments)
# Create a free account and copy the TEST secret key (sk_test_...) from
# https://dashboard.paystack.com/#/settings/developers
# Test card: 4084 0840 8408 4081, any future expiry, any CVV
PAYSTACK_SECRET_KEY=

# Optional: force a currency (NGN, GHS, ZAR, KES...). Leave empty to use your
# Paystack account's default currency — recommended, otherwise you may get
# "Currency not supported by merchant".
PAYSTACK_CURRENCY=
